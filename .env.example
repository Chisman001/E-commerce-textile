# Copy to Vercel Project Settings → Environment Variables (Production / Preview as needed).

# Neon / Postgres
DATABASE_URL=

# Clerk (Dashboard → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk → Webhooks → signing secret for /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=

# Optional: comma-separated Clerk user IDs for admin routes
ADMIN_USER_IDS=

# Cloudinary (admin image upload API)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Paystack (Dashboard → Settings → API Keys & Webhooks)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Resend (resend.com → API Keys)
RESEND_API_KEY=
